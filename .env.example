# Server encryption key for API key storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your-64-char-hex-key-here

# Optional: pin the OpenAI-compatible bearer token so serverless/ephemeral DB deploys do not regenerate it.
# FREEAPI_UNIFIED_API_KEY=freellmapi-your-stable-key

# Dashboard login. Required unless FREELLM_AUTH_DISABLED=1 is set for a trusted local-only dev run.
FREELLM_AUTH_USERNAME=change-me
FREELLM_AUTH_PASSWORD=change-me
# Optional: set a separate stable session-signing secret.
# FREELLM_AUTH_SECRET=your-random-session-secret

# Server port (default: 3001)
PORT=3001

# Luna Proxy sidecar (Qwen web chat bridge). The local sidecar starts on 8080
# with `npm run luna:dev`; set a public HTTPS URL here for Vercel/runtime use.
LUNA_PROXY_BASE_URL=http://127.0.0.1:8080/v1
# LUNA_PROXY_TIMEOUT_MS=300000

# Optional dashboard login override
# FREELLM_AUTH_USERNAME=admin
# FREELLM_AUTH_PASSWORD=change-me

# Add provider keys in the dashboard. Anthropic keys can be added as provider "anthropic".
# Luna can be added as provider "luna"; use Luna's proxy key, or any non-empty
# placeholder if the local Luna sidecar has no proxy.key configured.
